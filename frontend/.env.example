# Frontend development proxy configuration
# You can keep this aligned with ../.env, or override here when needed.

# Preferred shared variables
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5000

# Optional Vite-specific overrides (higher priority than BACKEND_*):
# VITE_BACKEND_HOST=127.0.0.1
# VITE_BACKEND_PORT=5000
# VITE_API_PROXY_TARGET=http://127.0.0.1:5000
